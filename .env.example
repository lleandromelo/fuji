# Caminho para o arquivo JSON com o inventário utilizado pelo assistente
INVENTORY_PATH=data/inventory.json

# Quantidade máxima de imagens enviadas por mensagem ao mostrar o catálogo
MEDIA_LIMIT=3

# Credenciais do Twilio (preencher apenas no ambiente de produção)
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=seu_token_twilio
TWILIO_WHATSAPP_NUMBER=whatsapp:+55XXXXXXXXXXX
